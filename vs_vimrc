" VSCode Vim 配置
" 基于原生 vimrc 调整，移除了 Vim 插件相关配置

set nocompatible
filetype indent on

" 拼写检查
set spell spelllang=en_us
setlocal spell spelllang=en_us,cjk

" 自动语法高亮
if has("syntax")
syntax on
endif

" 启用鼠标支持
set mouse=a
set background=light
set backspace=indent,eol,start

" 显示行号
set number
" 相对行号 nj/nk跳转
set relativenumber number

" 突出显示当前行
set cursorline

" 打开状态栏标尺
set ruler

" 设定 tab 长度
autocmd FileType c setlocal shiftwidth=2 tabstop=2 softtabstop=2
autocmd FileType cpp setlocal shiftwidth=2 tabstop=2 softtabstop=2
autocmd FileType python setlocal shiftwidth=4 tabstop=4 softtabstop=4
set tabstop=2
set softtabstop=2
set shiftwidth=2

" 设置空格代替tab
set expandtab

" 输入搜索内容时就显示搜索结果
set incsearch

" 插入括号时，短暂地跳转到匹配的对应括号
set showmatch
" 短暂跳转到匹配括号的时间
set matchtime=2

" 显示状态栏
set laststatus=2

" 高亮搜索结果
set hlsearch

" 设置自动对齐缩进
set autoindent
set cindent
set smartindent

set wildmenu

" 防止手滑的快捷键
map <F1> <ESC>
imap <F1> <ESC>
nnoremap ： :
cnoremap Q! q!
command Wq wq
command Q q
command WQ wq
command Wqa wqa

" 重新打开文件时跳转到上次位置
if has("autocmd")
  au BufReadPost * if line("'\"") > 1 && line("'\"") <= line("$") | exe "normal! g'\"" | endif
endif

" 行号切换函数
function! NumberToggle()
  if(&relativenumber == 1)
    set norelativenumber number
  else
    set relativenumber
  endif
endfunc
nnoremap <C-n> :call NumberToggle()<cr>
